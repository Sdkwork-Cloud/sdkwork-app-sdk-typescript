{
  "name": "@sdkwork/app-sdk",
  "version": "1.0.0",
  "description": "SDKWork App SDK - Professional TypeScript SDK for SDKWork Platform",
  "author": "SDKWork Team",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:types": "tsc --emitDeclarationOnly",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sdkwork",
    "sdk",
    "typescript",
    "api-client",
    "ai",
    "chat",
    "payment"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sdkwork/spring-ai-plus.git",
    "directory": "spring-ai-plus-business/spring-ai-plus-app-api/sdk/sdkwork-app-sdk-typescript"
  },
  "bugs": {
    "url": "https://github.com/sdkwork/spring-ai-plus/issues"
  },
  "homepage": "https://github.com/sdkwork/spring-ai-plus#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.2",
    "vite": "^5.0.4",
    "vite-plugin-dts": "^3.6.3",
    "vitest": "^1.0.4"
  }
}
